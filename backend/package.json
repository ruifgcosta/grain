{
  "name": "grain-backend",
  "version": "1.0.0",
  "description": "grain — backend Cloudflare Worker (Hono)",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:schema": "wrangler d1 execute grain --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute grain --local --file=src/db/seed.sql",
    "db:schema:prod": "wrangler d1 execute grain --file=src/db/schema.sql",
    "db:seed:prod": "wrangler d1 execute grain --file=src/db/seed.sql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  },
  "dependencies": {
    "hono": "^4.12.12"
  }
}
